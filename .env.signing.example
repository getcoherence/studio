# Azure Trusted Signing credentials for Coherence Studio Windows builds.
#
# Copy this file to .env.signing (gitignored) and fill in the values from
# the "Coherence Studio Code Signing" app registration in Entra.
#
# Load before building:
#   set -a; source .env.signing; set +a
#   npm run build:win

# Service principal (Entra app registration)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Full path to Azure.CodeSigning.Dlib.dll from the
# Microsoft.Trusted.Signing.Client NuGet package.
# Example: C:/Tools/TrustedSigning/bin/x64/Azure.CodeSigning.Dlib.dll
TRUSTED_SIGNING_DLIB_PATH=

# Optional — only set if signtool auto-detect fails.
# SIGNTOOL_PATH=C:/Program Files (x86)/Windows Kits/10/bin/10.0.26100.0/x64/signtool.exe
