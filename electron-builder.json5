// @see - https://www.electron.build/configuration/configuration
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "io.getcoherence.studio",
  "asar": true,
  // Remotion's compositor package ships native binaries (ffmpeg.exe,
  // ffprobe.exe, remotion.exe). Node can't spawn executables from inside
  // an asar archive, and electron-builder's auto-detection only catches
  // ffmpeg.exe here — ffprobe and remotion stay inside asar and fail
  // with ENOENT at export time. Force the whole compositor folder into
  // app.asar.unpacked so every binary is spawnable.
  "asarUnpack": [
    "node_modules/@remotion/compositor-*/**/*"
  ],
  "productName": "Coherence Studio",
  "npmRebuild": true,
  "buildDependenciesFromSource": true,
  "compression": "normal",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron",
    "!*.png",
    "!preview*.png",
    "!*.md",
    "!README.md",
    "!CONTRIBUTING.md",
    "!LICENSE"
  ],
  // ffmpeg ships with @remotion/compositor-<platform>-<arch>, which
  // electron-builder already unpacks into resources/app.asar.unpacked/
  // node_modules (native code cannot live inside asar). See
  // electron/ipc/showcaseHandlers.ts::findFfmpegBinary for the lookup path.
  "extraResources": [
    {
      "from": "public/wallpapers",
      "to": "assets/wallpapers"
    },
    {
      "from": "dist-remotion",
      "to": "remotion-bundle"
    }
  ],

  "mac": {
    // Notarization requires hardenedRuntime + an entitlements plist.
    // electron-builder runs the notarize step automatically when the
    // `APPLE_API_KEY_ID` / `APPLE_API_ISSUER` / `APPLE_API_KEY` env vars are
    // set (App Store Connect API key — newer / cleaner than ASP passwords).
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "notarize": true,
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "icons/icons/mac/icon.icns",
    "artifactName": "${productName}-Mac-${arch}-${version}-Installer.${ext}",
    "extendInfo": {
      "NSAudioCaptureUsageDescription": "Coherence Studio needs audio capture permission to record system audio.",
      "NSMicrophoneUsageDescription": "Coherence Studio needs microphone access to record voice audio.",
      "NSCameraUsageDescription": "Coherence Studio needs camera access to record webcam video.",
      "NSCameraUseContinuityCameraDeviceType": true,
      "com.apple.security.device.audio-input": true
    }
  },
  "linux": {
    "target": [
      "AppImage"
    ],
    "icon": "icons/icons/png",
    "artifactName": "${productName}-Linux-${version}.${ext}",
    "category": "AudioVideo"
  },
  "win": {
    "target": [
      "nsis"
    ],
    "icon": "icons/icons/win/icon.ico",
    // Azure Trusted Signing — custom hook invokes SignTool with the
    // Azure.CodeSigning.Dlib.dll. Auth + tool paths come from env vars;
    // see signing/sign.js for the full list. electron-builder 26.x moved
    // signing config under `signtoolOptions` (was flat on `win` in 25.x).
    "signtoolOptions": {
      "sign": "./signing/sign.cjs",
      "signingHashAlgorithms": ["sha256"],
      // Must match the CN on the Azure Trusted Signing cert EXACTLY —
      // electron-updater compares the signer's CN against this value
      // when verifying downloaded installers. Previously "Brightyard",
      // which caused every update check to throw a giant signature-
      // verification dump into the error toast because the signer walk
      // never matched.
      "publisherName": "Brightyard, Inc"
    }
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "allowElevation": true,
    "deleteAppDataOnUninstall": false,
    "uninstallDisplayName": "Coherence Studio",
    "installerIcon": "icons/icons/win/icon.ico",
    "uninstallerIcon": "icons/icons/win/icon.ico"
  },
  // Auto-update target. electron-builder writes `latest.yml` +
  // `latest-mac.yml` + `latest-linux.yml` alongside the installer on
  // release publish; electron-updater (runtime) reads these to detect new
  // versions. Prerelease tags (e.g. v1.0.0-beta.1) publish to the "beta"
  // channel automatically because `allowPrerelease` is set in updater.ts
  // when the user opts into Beta.
  "publish": [
    {
      "provider": "github",
      "owner": "getcoherence",
      "repo": "studio",
      // Draft, not release — builds land unpublished so you can download
      // and smoke-test the installer on each platform before promoting
      // to "Latest" (which is what the auto-updater and
      // /releases/latest page serve to users). Once verified, publish
      // via the GitHub UI or `gh release edit vX.Y.Z --draft=false
      // --latest`.
      "releaseType": "draft"
    }
  ],
  "protocols": [
    {
      "name": "Coherence Studio",
      "schemes": ["coherence-studio"]
    }
  ],
  // Double-clicking a .studio file opens it in Coherence Studio.
  // Icon defaults to the app icon; swap in a dedicated document icon
  // once one is designed.
  "fileAssociations": [
    {
      "ext": "studio",
      "name": "Coherence Studio Project",
      "description": "Coherence Studio Project",
      "role": "Editor"
    }
  ]
}
